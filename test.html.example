<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>TDW Editor - Round Trip Test</title>
  <style>
    body { font-family: monospace; max-width: 900px; margin: 2rem auto; padding: 0 1rem; background: #1a1a1a; color: #e0e0e0; }
    h1 { color: #f0c040; }
    h2 { color: #a0d0f0; margin-top: 2rem; }
    textarea { width: 100%; height: 120px; background: #111; color: #e0e0e0; border: 1px solid #444; padding: .5rem; font-family: monospace; box-sizing: border-box; }
    button { margin: .5rem .25rem 0 0; padding: .4rem 1rem; background: #2a4a7f; color: #fff; border: none; cursor: pointer; }
    button:hover { background: #3a6abf; }
    pre { background: #111; border: 1px solid #333; padding: 1rem; overflow-x: auto; white-space: pre-wrap; word-break: break-all; }
    .slot { display: inline-block; border: 1px solid #444; padding: 2px 6px; margin: 2px; font-size: .8rem; }
    .slot.rest { color: #666; }
    .slot.sound { color: #8df; }
    .slot.chord { color: #fd8; border-color: #fd8; }
    .slot.pass { color: #f88; border-color: #f88; }
    .label { font-size: .75rem; color: #888; margin-top: .5rem; }
  </style>
</head>
<body>
<h1>🗿 TDW Editor -- Round Trip Test</h1>
<p>Paste a TDW sequence, import it, inspect the parsed slots, then re-export to verify the output is valid.</p>

<h2>Input</h2>
<textarea id="input" placeholder="Paste a .🗿 sequence here, e.g:  !speed@120|kick|_pause|snare|!combine|hihat|_pause=3|boom@2"></textarea>
<button id="btnImport">Import →</button>
<button id="btnSample">Load sample</button>

<h2>Parsed Slots</h2>
<div class="label">BPM: <span id="bpmDisplay">—</span> &nbsp; Slots: <span id="slotCount">—</span></div>
<div id="slotDisplay" style="margin-top:.5rem"></div>

<h2>Re-exported Sequence</h2>
<pre id="output">—</pre>
<button id="btnCopy">Copy to clipboard</button>
<button id="btnOpenTDW">Open in TDW</button>

<h2>Project JSON (.tde)</h2>
<pre id="jsonOutput">—</pre>

<script type="module">
  import { importFromTDW } from './io/parser.js'
  import { exportToTDW }   from './io/exporter.js'
  import { Project }       from './model/project.js'

  let currentProject = null

  const SAMPLE = '!speed@120|kick|_pause|snare|!combine|hihat|kick@2|_pause=3|boom|!combine|ding@-3|!volume@80|kick'

  document.getElementById('btnSample').onclick = () => {
    document.getElementById('input').value = SAMPLE
  }

  document.getElementById('btnImport').onclick = () => {
    const text = document.getElementById('input').value.trim()
    if (!text) return

    try {
      currentProject = importFromTDW(text)
      renderSlots(currentProject)
      document.getElementById('bpmDisplay').textContent = currentProject.bpm
      document.getElementById('slotCount').textContent  = currentProject.slots.length

      const exported = exportToTDW(currentProject)
      document.getElementById('output').textContent = exported
      document.getElementById('jsonOutput').textContent = JSON.stringify(currentProject.toJSON(), null, 2)
    } catch (e) {
      document.getElementById('output').textContent = `Error: ${e.message}`
      console.error(e)
    }
  }

  document.getElementById('btnCopy').onclick = () => {
    const text = document.getElementById('output').textContent
    navigator.clipboard.writeText(text)
  }

  document.getElementById('btnOpenTDW').onclick = () => {
    const text = document.getElementById('output').textContent
    if (text && text !== '—') {
      window.open(`https://thirtydollar.website/#${encodeURIComponent(text)}`, '_blank')
    }
  }

  function renderSlots(project) {
    const container = document.getElementById('slotDisplay')
    container.innerHTML = ''

    for (const slot of project.slots) {
      const el = document.createElement('span')
      el.className = 'slot'

      if (slot._passthrough) {
        el.className += ' pass'
        el.title = 'Passthrough control item'
        el.textContent = slot._passthrough
      } else if (slot.isRest) {
        el.className += ' rest'
        el.textContent = `_pause (${slot.duration})`
      } else if (slot.sounds.length > 1) {
        el.className += ' chord'
        el.title = `Chord: ${slot.sounds.map(s => s.id).join(' + ')}`
        el.textContent = slot.sounds.map(s => s.id + (s.pitch ? `@${s.pitch}` : '')).join('+')
      } else {
        el.className += ' sound'
        const s = slot.sounds[0]
        el.textContent = s.id + (s.pitch ? `@${s.pitch}` : '')
      }

      container.appendChild(el)
    }
  }
</script>
</body>
</html>
